# LLM provider selection
# Supported values: ollama, openai, qwen
LLM_PROVIDER=ollama

# Local Qwen through Ollama
# Install Ollama, then run: ollama pull qwen3
OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
OLLAMA_MODEL=qwen3:latest
OLLAMA_API_KEY=ollama

# Qwen / DashScope OpenAI-compatible API
# Official compatible base URL:
# https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_API_KEY=
QWEN_MODEL=qwen-plus
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Alias supported by the app if you prefer DashScope naming.
# DASHSCOPE_API_KEY=

# Closed-network Kwan/Kwan-like OpenAI-compatible API for the TUI POC.
# KWAN_BASE_URL may be either .../v1 or .../v1/chat/completions.
KWAN_API_KEY=
KWAN_BASE_URL=http://127.0.0.1:8000/v1
KWAN_MODEL=qwen3.6
KWAN_TEMPERATURE=0.2

# OpenAI fallback
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
